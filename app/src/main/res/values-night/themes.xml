<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.XCodeApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/splash_bg_dark</item>
    </style>

    <style name="Theme.XCodeApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.XCodeApp</item>
    </style>
</resources>